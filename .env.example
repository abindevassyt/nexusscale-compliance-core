# =============================================================================
# NexusScale Compliance Engine — Environment Configuration
# Copy this file to .env and populate values before starting the service.
# NEVER commit .env to version control.
# =============================================================================

# ── REQUIRED: Runtime Security Secret (minimum 16 characters) ────────────────
# The system will ABORT on startup if this is absent, blank, or too short.
ENTERPRISE_AGENT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_32CHARS

# ── Application Identity ─────────────────────────────────────────────────────
APP_ENV=development                      # development | staging | production
APP_NAME=NexusScale Compliance Engine
APP_VERSION=1.0.0
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR

# ── FastAPI Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# ── MCP Database Bridge ──────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:9000/mcp
MCP_TRANSPORT=jsonrpc                    # jsonrpc | stdio
MCP_TIMEOUT_SECONDS=10
MCP_MAX_RETRIES=3
MCP_CIRCUIT_BREAKER_THRESHOLD=5         # failures before circuit opens
MCP_CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# ── Policy Engine ────────────────────────────────────────────────────────────
POLICY_RULES_PATH=config/policy_rules.json
DEFAULT_POLICY_LIMIT_USD=50.00

# ── Slack Webhook (ResolutionCommunicator) ───────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_DEFAULT_CHANNEL=#compliance-alerts
SLACK_RETRY_ATTEMPTS=3

# ── Microsoft Teams Webhook ──────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/YOUR_WEBHOOK_ID

# ── Session Key Validation ───────────────────────────────────────────────────
SESSION_HMAC_SECRET=CHANGE_ME_SESSION_HMAC_SECRET_32CH
SESSION_KEY_TTL_SECONDS=3600

# ── Audit Database ───────────────────────────────────────────────────────────
AUDIT_DB_URL=sqlite+aiosqlite:///./audit_trail.db
# For production PostgreSQL:
# AUDIT_DB_URL=postgresql+asyncpg://user:password@localhost:5432/nexusscale_audit

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20
